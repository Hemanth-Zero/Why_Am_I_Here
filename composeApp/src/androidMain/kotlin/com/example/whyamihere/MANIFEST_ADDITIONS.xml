<!--
  ╔══════════════════════════════════════════════════════════════╗
  ║  AndroidManifest ADDITIONS for Why Am I Here v2.0           ║
  ║  Add these to your existing composeApp/src/androidMain/      ║
  ║  AndroidManifest.xml                                         ║
  ╚══════════════════════════════════════════════════════════════╝

  1. PERMISSIONS – add inside <manifest> before <application>:
-->

<!-- Already present: SYSTEM_ALERT_WINDOW, PACKAGE_USAGE_STATS -->
<!-- ADD these if not already present: -->
<uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
<uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE"/>
<uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

<!--
  2. SERVICES – add inside <application>:
-->

<!-- BreakTimerService: counts down, shows notification, re-triggers overlay -->
<service
    android:name=".BreakTimerService"
    android:exported="false"
    android:foregroundServiceType="specialUse">
    <property
        android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
        android:value="breakTimer"/>
</service>

